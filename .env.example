# GridlockDM — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────
DB_USERNAME=gridlock
DB_PASSWORD=gridlock

# ── JWT ───────────────────────────────────────────────────────────
# REQUIRED: Change this to a long random string before deploying.
# Generate one with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters-long

# ── Server ────────────────────────────────────────────────────────
PORT=8080
